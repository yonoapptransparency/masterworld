rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ID checking helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidAdminId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-@.]+$');
    }

    // Helper to verify if user is authorized as an admin (via database index lookup)
    // Checks that the email is verified to prevent unverified email spoofing attacks
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email.lower() == 'defentechscholar@gmail.com' ||
              exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))));
    }

    // Comprehensive payload validation for reviews
    function isValidReview(data) {
      return data.keys().hasAll(['app_id', 'username', 'rating', 'comment', 'created_at', 'helpful_count', 'is_approved', 'source']) &&
             data.keys().size() == 8 &&
             data.app_id is string && data.app_id.size() <= 128 &&
             data.username is string && data.username.size() <= 200 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.helpful_count is number &&
             data.is_approved is bool &&
             data.source is string && data.source.size() <= 128;
    }

    // Comprehensive payload validation for website feedback
    function isValidFeedback(data) {
      return data.keys().hasAll(['username', 'rating', 'comment', 'created_at', 'source']) &&
             data.keys().size() == 5 &&
             data.username is string && data.username.size() <= 200 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.source is string && data.source.size() <= 128;
    }

    // Comprehensive payload validation for support tickets
    function isValidTicket(data) {
      return data.keys().hasAll(['username', 'email', 'comment', 'created_at', 'status', 'source']) &&
             data.keys().size() == 6 &&
             data.username is string && data.username.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.comment is string && data.comment.size() <= 3000 &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.status is string && data.status.size() <= 64 &&
             data.source is string && data.source.size() <= 128;
    }

    // 1. Admins collection
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // 2. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true; // Public can read reviews
      allow create: if isValidReview(request.resource.data); // Anyone can create a valid review
      allow update, delete: if isAdmin(); // Only admins can moderate/delete reviews
    }

    // 3. Website feedback collection
    match /website_feedback/{feedbackId} {
      allow read: if isAdmin(); // Only admins can view feedback list
      allow create: if isValidFeedback(request.resource.data); // Anyone can submit feedback
      allow update, delete: if isAdmin();
    }

    // 4. Support tickets collection
    match /support_tickets/{ticketId} {
      allow read: if isAdmin(); // Only admins can read tickets
      allow create: if isValidTicket(request.resource.data); // Anyone can open a ticket
      allow update, delete: if isAdmin();
    }

    // 5. Store data collection
    match /store_data/{docId} {
      // Sensitive system settings and config keys must ONLY be read/written by admins
      // This protects Git config (including personal access token) and secure links
      allow read, write: if isAdmin();

      // Non-sensitive public data documents can be read by anyone
      allow read: if docId in [
        'apps', 'apps_meta', 'public_settings', 'categories', 'faqs', 'developers',
        'news', 'blogs', 'videos', 'quick_links'
      ] || docId.startsWith('apps_chunk_');
    }

    // 6. Secure Git Configuration collection
    match /sec_git/{docId} {
      allow read, write: if isAdmin();
    }

    // 7. Spent Tokens collection (Token replay protection)
    match /spent_tokens/{tokenId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['usedAt']) &&
                    request.resource.data.keys().size() == 1 &&
                    request.resource.data.usedAt is string;
      allow update, delete: if false;
    }

    // Default catch-all deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
